{
  "$schema": "https://opencode.ai/config.json",
  // NOTE: Superpowers plugin is managed externally
  // Install/update separately via: ~/.dotfiles/.config/opencode/scripts/install-superpowers.sh
  // See .config/opencode/README.md for details
  
  // TUI-specific settings for the terminal interface
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    }
  },
}
